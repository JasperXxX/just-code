# Config template for claude-progress-watcher.
# Copy to `~/.claude/progress-watcher.env` and fill in the URLs/keys you use.
# Comment a line to disable that detector. The watcher will skip silently if
# a host is unreachable or a key is missing — leaving everything commented out
# is fine, it'll just sit idle until a Remotion or ffmpeg process appears.

# --- Polling --------------------------------------------------------------
WATCH_INTERVAL=2          # seconds between polls

# --- ComfyUI -------------------------------------------------------------
# Default local install runs on :8188. Adjust if you moved it.
# COMFYUI_URL="http://127.0.0.1:8188"

# --- OctoPrint --------------------------------------------------------
# Settings → API → "API Key" inside the OctoPrint web UI.
# OCTOPRINT_PRUSA_URL="http://octoprint.local"
# OCTOPRINT_PRUSA_KEY=""

# --- Moonraker (Klipper-based printers: Voron, V-Core, etc.) -------------
# Moonraker exposes /printer/objects/query — different from OctoPrint.
# MOONRAKER_VORON_URL="http://printer.local"

# --- Remotion / ffmpeg process detection ---------------------------------
DETECT_REMOTION=1
DETECT_FFMPEG=1

# --- DaVinci-Flow HTTP Bridge --------------------------------------------
# The community DaVinci Resolve scripting bridge. Off by default — the
# bridge isn't always running, so polling it adds noise to the log.
# DAVINCI_BRIDGE_URL="http://127.0.0.1:50080"
# DETECT_DAVINCI=0
